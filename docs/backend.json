
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile, including their identity, learning progression, and gamified statistics.",
      "properties": {
        "id": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "avatar": {
          "type": "string"
        },
        "activeTitleId": {
          "type": "string"
        },
        "earnedBadgeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unlockedTitleIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "currentCocId": {
          "type": "string"
        },
        "currentStepId": {
          "type": "string"
        },
        "profileBackgroundId": {
          "type": "string"
        },
        "profileBackgroundUrl": {
          "type": "string"
        },
        "chatBackgroundId": {
          "type": "string"
        },
        "chatBackgroundUrl": {
          "type": "string"
        },
        "specialBackground": {
          "type": "string",
          "enum": ["angelic", "cabbage"]
        },
        "chatSpecialBackground": {
          "type": "string",
          "enum": ["angelic", "cabbage"]
        },
        "totalQuizAttempts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "totalFullResets": {
          "type": "number",
          "format": "integer"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "role": {
          "type": "string",
          "format": "enum"
        }
      },
      "required": [
        "id",
        "username",
        "email",
        "avatar",
        "createdAt",
        "role"
      ]
    },
    "AiChatMessage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AiChatMessage",
      "type": "object",
      "description": "A single message in the AI conversation history.",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    },
    "AchievementLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AchievementLog",
      "type": "object",
      "description": "Records individual instances of badges or titles earned by a user.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "format": "enum"
        },
        "entityId": {
          "type": "string"
        },
        "entityName": {
          "type": "string"
        },
        "earnedAt": {
          "type": "string",
          "format": "date-time"
        },
        "description": {
          "type": "string"
        },
        "isSpecialAchievement": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "userId",
        "type",
        "entityId",
        "earnedAt"
      ]
    },
    "ChatMessage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChatMessage",
      "type": "object",
      "description": "Represents a single message within a chat session.",
      "properties": {
        "id": {
          "type": "string"
        },
        "senderId": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "imageUrl": {
          "type": "string",
          "description": "Optional data URL or URL for a shared image."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "senderId",
        "message",
        "timestamp"
      ]
    },
    "FeedbackPost": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FeedbackPost",
      "type": "object",
      "description": "Represents a feedback transmission on the board.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "avatar": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "specialInsignia": { "type": "string", "enum": ["black-flame"] }
      },
      "required": ["id", "userId", "username", "displayName", "message", "timestamp"]
    },
    "FeedbackReply": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FeedbackReply",
      "type": "object",
      "description": "Represents a reply to a feedback transmission.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "avatar": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "specialInsignia": { "type": "string", "enum": ["black-flame"] }
      },
      "required": ["id", "userId", "username", "displayName", "message", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores a user's profile data.",
          "params": [
            { "name": "userId", "description": "UID" }
          ]
        }
      },
      {
        "path": "/users/{userId}/aiHistory/history",
        "definition": {
          "entityName": "AiConversation",
          "schema": {
            "type": "object",
            "properties": {
              "messages": {
                "type": "array",
                "items": { "$ref": "#/backend/entities/AiChatMessage" }
              }
            }
          },
          "description": "Stores AI conversation history for the user.",
          "params": [
            { "name": "userId", "description": "UID" }
          ]
        }
      },
      {
        "path": "/feedback/{feedbackId}",
        "definition": {
          "entityName": "FeedbackPost",
          "schema": {
            "$ref": "#/backend/entities/FeedbackPost"
          },
          "description": "Public feedback transmissions.",
          "params": [
            { "name": "feedbackId", "description": "ID" }
          ]
        }
      },
      {
        "path": "/feedback/{feedbackId}/replies/{replyId}",
        "definition": {
          "entityName": "FeedbackReply",
          "schema": {
            "$ref": "#/backend/entities/FeedbackReply"
          },
          "description": "Replies to specific feedback transmissions.",
          "params": [
            { "name": "feedbackId", "description": "ID of parent" },
            { "name": "replyId", "description": "ID of reply" }
          ]
        }
      },
      {
        "path": "/chats/{chatId}/messages/{messageId}",
        "definition": {
          "entityName": "ChatMessage",
          "schema": {
            "$ref": "#/backend/entities/ChatMessage"
          },
          "description": "Messages between users.",
          "params": [
            { "name": "chatId", "description": "Combined UID of two users" },
            { "name": "messageId", "description": "Message ID" }
          ]
        }
      }
    ]
  }
}
